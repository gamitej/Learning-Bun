{
  "name": "bun-backend-setup",
  "version": "1.0.0",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=production bun src/server.ts",
    "dev": "NODE_ENV=development bun --hot src/server.ts",
    "build": "bun build ./src/server.ts --outdir ./dist --target bun --minify",
    "db:push": "bunx drizzle-kit push",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio",
    "prepare": "husky",
    "test": "NODE_ENV=test bun test",
    "test:unit": "NODE_ENV=test bun test ./tests/unit",
    "test:watch": "NODE_ENV=test bun test --watch",
    "stress": "k6 run tests/stress.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "clean:idempotency": "NODE_ENV=production bun src/scripts/cleanup-idempotency.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "0.18.3",
    "@hono/zod-validator": "^0.4.2",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.6.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@types/bun": "latest",
    "@types/k6": "^0.54.0",
    "drizzle-kit": "^0.24.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "typescript": "^5.6.2"
  }
}